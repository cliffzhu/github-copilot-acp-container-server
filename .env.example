ACP_PORT=3000
ACP_AGENT=ACP-Chatbot
ACP_WORKDIR=/workspace
ACP_AVAILABLE_TOOLS=glob,rg,read_agent,list_agents,view,skill
ACP_DISALLOW_TEMP_DIR=true
ACP_DISABLE_BUILTIN_MCPS=true
ACP_REQUIRE_LOGIN=true
ACP_AUTH_METHOD_ID=
COPILOT_GITHUB_TOKEN=
GH_TOKEN=
GITHUB_TOKEN=
ACP_LOGIN_STORE_PLAINTEXT=true
ACP_LOGIN_USE_EXPECT=false
ACP_COPILOT_SELF_HEAL=true
ACP_BIND_ALL_INTERFACES=true
ACP_INTERNAL_PORT=3001
ACP_BOOTSTRAP_DEFAULT_AGENT=true
ACP_WEBSOCKET_PORT=
WEBSOCKET_TOKEN=
WEBSOCKET_USER=token
ACP_WEBSOCKET_TARGET_HOST=127.0.0.1
ACP_WEBSOCKET_CONTAINER_NAME=acp-websocket-proxy
ACP_WEBSOCKET_ADAPTER_IMAGE=acp-websocket-adapter:local
